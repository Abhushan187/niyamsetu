# ─────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────

# Byte-compiled files Python creates automatically — not needed in repo
__pycache__/
*.py[cod]
*$py.class

# Virtual environment folder — each person creates their own locally
venv/
env/
.env/
.venv/

# Environment variables file — contains secrets, NEVER push this
.env

# Distribution / packaging
dist/
build/
*.egg-info/

# Pytest cache
.pytest_cache/
*.log

# ─────────────────────────────────────────
# NODE / REACT FRONTEND
# ─────────────────────────────────────────

# node_modules has 150,000+ files — everyone installs their own via npm install
node_modules/

# Vite build output — generated, not source code
frontend/dist/
frontend/.vite/

# ─────────────────────────────────────────
# PROJECT DATA — LOCAL ONLY
# ─────────────────────────────────────────

# Uploaded GR PDFs — too large for GitHub, sensitive government documents
backend/data/grdocs/

# FAISS vector store files — generated by running embed, not source code
backend/data/vectorstore/

# Generated summary files
backend/data/summaries/

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────

# MongoDB local data directory if running locally
data/db/

# SQLite files if used for testing
*.db
*.sqlite3

# ─────────────────────────────────────────
# EDITORS & OS
# ─────────────────────────────────────────

# VS Code settings — personal preference, not project config
.vscode/
*.code-workspace

# Mac OS junk files
.DS_Store

# Windows thumbnail cache
Thumbs.db

# JetBrains IDEs (PyCharm, WebStorm)
.idea/

# ─────────────────────────────────────────
# TEST OUTPUT
# ─────────────────────────────────────────

# Generated HTML report from test runner
tests/GR_Test_Report.html
tests/*_results.json